# Open Nova local overrides. Copy to .env only for local development.
# The installer writes durable runtime settings under ~/.open-nova.

# Paths
WORKSPACE_DIR=/path/to/open-nova
NOVA_HOME=~/.open-nova
DIARY_OUTPUT_DIR=~/.open-nova/artifacts/diary
TMP_WORKSPACE=~/.open-nova/state/tmp

# API Keys & LLM
LLM_API_KEY=your_api_key_here
LLM_HOST=https://api.minimaxi.com
LLM_MODEL_NAME=MiniMax-M2.7-highspeed

# Database
TASK_DB_PATH=~/.open-nova/data/nova_tasks.db

# Misc
TARGET_TIMEZONE=Asia/Hong_Kong
