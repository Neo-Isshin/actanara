# Actanara local overrides. Copy to .env only for local development.
# The installer writes durable runtime settings under ~/.actanara.

# Paths
WORKSPACE_DIR=/path/to/actanara
ACTANARA_HOME=~/.actanara
DIARY_OUTPUT_DIR=~/.actanara/artifacts/diary
TMP_WORKSPACE=~/.actanara/state/tmp

# API Keys & LLM
LLM_API_KEY=your_api_key_here
LLM_HOST=https://api.minimaxi.com
LLM_MODEL_NAME=MiniMax-M2.7-highspeed

# Database
TASK_DB_PATH=~/.actanara/data/nova_tasks.db

# Misc
TARGET_TIMEZONE=Asia/Hong_Kong
